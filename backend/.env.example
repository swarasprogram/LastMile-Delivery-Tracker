# ── Database ──────────────────────────────────────────────────────────────
# PostgreSQL with the PostGIS extension enabled.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/delivery_tracker

# ── Auth ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Email notifications (Brevo, optional / free tier) ──────────────────────
BREVO_API_KEY=
SENDER_EMAIL=noreply@deliverytracker.com

# ── Payments: Stripe test mode ─────────────────────────────────────────────
# Create a free account and copy your TEST keys from:
#   https://dashboard.stripe.com/test/apikeys
# Fill these in your local .env (NOT here). The secret key begins with
# "sk_test_" and the publishable key with "pk_test_".
# Prepaid checkout uses Stripe Checkout; test card: 4242 4242 4242 4242, any
# future expiry, any CVC. Refunds on failed deliveries use the Stripe Refund API.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
CURRENCY=inr

# Must match where the frontend runs — Stripe redirects the customer back here
# after payment (e.g. http://localhost:5173 or http://localhost:5174).
FRONTEND_URL=http://localhost:5173
